# Large media — never commit raw recordings or final renders to git
*.mov
*.mp4
*.m4a
*.wav
*.mkv

# Python
__pycache__/
*.pyc
.venv/
venv/

# Work scratch / intermediate render artifacts
work/
clips/
*.bak
.DS_Store

# All media output (raw, finals, clips) — regenerable, not for git
media/

# YouTube uploader — never commit OAuth secrets or upload state
client_secret*.json
token.json
*.results.json
